<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Recognizer.Gui.Views"
        xmlns:vm="using:Recognizer.Gui.ViewModels"
        xmlns:models="using:Recognizer.Gui.Models"
        x:Class="Recognizer.Gui.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Recognizer"
        Width="1000" Height="720">

  <!-- 上段: 左=入力パネル / 中央=画像プレビュー+オーバーレイ、下段: 結果一覧(要件 8.1) -->
  <Grid RowDefinitions="*,Auto">

    <Grid Grid.Row="0" ColumnDefinitions="340,*">

      <!-- 入力パネル -->
      <ScrollViewer Grid.Column="0" Padding="12">
        <StackPanel Spacing="10">

          <TextBlock Text="モデルファイル" FontWeight="Bold" />
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" IsReadOnly="True" Text="{Binding ModelPath}"
                     PlaceholderText="モデル(.onnx)を選択" />
            <Button Grid.Column="1" Content="参照" Margin="6,0,0,0" Click="OnBrowseModel" />
          </Grid>

          <TextBlock Text="入力画像" FontWeight="Bold" />
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" IsReadOnly="True" Text="{Binding ImagePath}"
                     PlaceholderText="画像を選択" />
            <Button Grid.Column="1" Content="参照" Margin="6,0,0,0" Click="OnBrowseImage" />
          </Grid>

          <TextBlock Text="検出モード" FontWeight="Bold" />
          <ComboBox x:Name="ModeComboBox" HorizontalAlignment="Stretch"
                    SelectionChanged="OnModeChanged">
            <ComboBoxItem Content="顔検出" />
            <ComboBoxItem Content="物体検出" />
          </ComboBox>

          <TextBlock Text="信頼度閾値" FontWeight="Bold" />
          <TextBox Text="{Binding ConfidenceThreshold}" />

          <TextBlock Text="NMS 閾値" FontWeight="Bold" />
          <TextBox Text="{Binding NmsThreshold}" />

          <TextBlock Text="クラス名ファイル(物体検出時のみ)" FontWeight="Bold" />
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" IsReadOnly="True" Text="{Binding ClassNamesPath}"
                     IsEnabled="{Binding IsClassNamesEnabled}"
                     PlaceholderText="1 行 1 クラス名(省略可)" />
            <Button Grid.Column="1" Content="参照" Margin="6,0,0,0"
                    IsEnabled="{Binding IsClassNamesEnabled}" Click="OnBrowseClassNames" />
          </Grid>

          <Button Content="検出を実行" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                  IsEnabled="{Binding !IsBusy}" Click="OnRun" />

          <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#555" />

        </StackPanel>
      </ScrollViewer>

      <!-- 画像プレビュー + オーバーレイ(同一領域に重ねて座標系を一致させる) -->
      <Border Grid.Column="1" Margin="12" Background="#202020" ClipToBounds="True">
        <Grid>
          <Image x:Name="PreviewImage" Stretch="Uniform" />
          <views:DetectionOverlayControl x:Name="Overlay" />
        </Grid>
      </Border>

    </Grid>

    <!-- 結果一覧(要件 8.3) -->
    <Border Grid.Row="1" Height="180" BorderBrush="#CCC" BorderThickness="0,1,0,0">
      <DockPanel Margin="12,6">
        <TextBlock DockPanel.Dock="Top" Text="検出結果" FontWeight="Bold" Margin="0,0,0,6" />
        <ListBox ItemsSource="{Binding Detections}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:DetectionOverlay">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Label}" />
                <TextBlock Grid.Column="1" Text="{Binding Confidence, StringFormat='0.00'}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

  </Grid>

</Window>
